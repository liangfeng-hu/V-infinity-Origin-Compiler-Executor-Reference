{
  "openapi": "3.0.3",
  "info": {
    "title": "V∞ Gate91 I_ENTROPY_CLONE API (Reference)",
    "version": "v1.0",
    "description": "Reference interface for Gate91 physical decidability. Mock placeholders only."
  },
  "paths": {
    "/gate91/evaluate": {
      "post": {
        "summary": "Evaluate physical proof / attestation (mock placeholders)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Gate91Request" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gate91 verdict",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Gate91Verdict" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Gate91Request": {
        "type": "object",
        "required": ["req_id", "physical_proof"],
        "properties": {
          "req_id": { "type": "string" },
          "physical_proof": {
            "type": "object",
            "required": ["thermo_proof_ok", "attestation_ok"],
            "properties": {
              "thermo_proof_ok": { "type": "boolean" },
              "attestation_ok": { "type": "boolean" },
              "entropy_clone_risk_code": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "Gate91Verdict": {
        "type": "object",
        "required": ["i_91", "thermo_proof_ok", "attestation_ok", "entropy_clone_risk_code"],
        "properties": {
          "i_91": { "type": "integer", "enum": [0, 1] },
          "thermo_proof_ok": { "type": "boolean" },
          "attestation_ok": { "type": "boolean" },
          "entropy_clone_risk_code": { "type": "string" }
        }
      }
    }
  }
}
